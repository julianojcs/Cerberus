# ============================================================================
# .env.example — Padrão Estrutural de Configuração do Cerberus
# Copie para `.env` e ajuste. NUNCA versione o arquivo .env real (segredos).
# O código abstrai a infraestrutura via injeção de variáveis (12-factor),
# permitindo migração MVP (custo-zero) -> Produção DTI sem alterar código.
#
# Deploy público (Render + Atlas M0 + HiveMQ): docs/runbooks/deploy-mvp.md.
# Em produção os segredos são definidos no painel do provedor (nunca em arquivo):
# CORS_ORIGINS = domínio do dashboard publicado; JWT_SECRET forte/gerado.
# ============================================================================

# --- API (Servidor Central Fastify) ---
PORT=3000
NODE_ENV=development
API_HOST=0.0.0.0
# Origens permitidas para CORS (dashboard). Separe por vírgula.
CORS_ORIGINS=http://localhost:3001

# --- Parâmetros de Persistência (MongoDB) ---
# MVP:    mongodb://localhost:27017/cerberus_db   (docker-compose local)
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>/cerberus_db
# DTI:    mongodb://usuario_pf:senha_forte_local@cluster-dti:27017/cerberus_db?replicaSet=rs0
MONGO_URI=mongodb://localhost:27017/cerberus_db

# --- Parâmetros de Mensageria MQTT (barramento tático) ---
# MVP local (mosquitto):  mqtt://localhost:1883
# HiveMQ Cloud:           mqtts://<cluster>.hivemq.cloud:8883
# DTI on-prem:            mqtts://cerberus.mqtt.pf.gov.br:8883
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=cerberus_api_node
# Credenciais privilegiadas da PONTE da API (subscriber que persiste telemetria).
MQTT_USERNAME=
MQTT_PASSWORD=

# --- Assinatura de Segurança (JWT) ---
# Troque por segredo forte em produção. O mesmo token autentica REST e conexão MQTT.
JWT_SECRET=token_de_assinatura_de_seguranca_corporativa_dti
JWT_EXPIRES_IN=8h

# ============================================================================
# Dashboard (Next.js) — variáveis expostas ao browser precisam do prefixo NEXT_PUBLIC_
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3000
# Endpoint MQTT sobre WebSockets para plotagem em tempo real (sem passar pelo banco).
# MVP local (mosquitto WS): ws://localhost:9001
# HiveMQ Cloud (WSS):       wss://<cluster>.hivemq.cloud:8884/mqtt
NEXT_PUBLIC_MQTT_WS_URL=ws://localhost:9001

# ============================================================================
# Mobile (Expo) — configurado em apps/mobile/.env (prefixo EXPO_PUBLIC_)
# ============================================================================
# EXPO_PUBLIC_API_URL=http://<ip-da-maquina>:3000
# EXPO_PUBLIC_MQTT_WS_URL=ws://<ip-da-maquina>:9001
