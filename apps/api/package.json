{
  "name": "@cerberus/api",
  "version": "0.1.0",
  "description": "API de Serviços (Servidor Central) do Cerberus — Fastify + ponte MQTT.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=../../.env dist/server.js",
    "seed": "tsx --env-file-if-exists=../../.env src/scripts/seed.ts",
    "sim": "tsx --env-file-if-exists=../../.env src/scripts/simulate-agents.ts",
    "sim:setup": "tsx --env-file-if-exists=../../.env src/scripts/setup-simulation.ts",
    "ensure-superadmin": "tsx --env-file-if-exists=../../.env src/scripts/ensure-superadmin.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@cerberus/shared": "*",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^10.2.1",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "mongoose": "^8.9.2",
    "mqtt": "^5.10.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "aedes": "^1.1.1",
    "form-data": "^4.0.6",
    "mongodb-memory-server": "^11.2.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
