# Configuração do app móvel (Expo). Copie para `.env`.
# Use o IP da sua máquina na rede local (não "localhost") para o celular alcançar
# a API e o broker durante o desenvolvimento.
EXPO_PUBLIC_API_URL=http://192.168.0.10:3000
EXPO_PUBLIC_MQTT_WS_URL=ws://192.168.0.10:9001

# Licença do react-native-background-geolocation para o binário OFICIAL (plano
# Starter). Deixe vazio no MVP / modo debug.
BACKGROUND_GEOLOCATION_LICENSE=
