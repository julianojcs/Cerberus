{
  "name": "cerberus-mobile",
  "version": "0.1.0",
  "description": "Aplicação Móvel de Campo (Agentes) do Cerberus — Expo / React Native.",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "set-ip": "node scripts/set-ip.mjs",
    "make-icons": "node scripts/make-icons.mjs",
    "start": "node scripts/set-ip.mjs && expo start --dev-client --lan",
    "start:tunnel": "expo start --dev-client --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "typecheck": "tsc --noEmit",
    "test": "node --test plugins/gradle-transforms.test.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "buffer": "^6.0.3",
    "events": "^3.3.0",
    "expo": "~52.0.0",
    "expo-application": "~6.0.2",
    "expo-asset": "~11.0.5",
    "expo-camera": "~16.0.0",
    "expo-file-system": "~18.0.12",
    "expo-image-picker": "~16.0.6",
    "expo-notifications": "~0.29.14",
    "expo-secure-store": "~14.0.0",
    "expo-speech": "~13.0.1",
    "expo-status-bar": "~2.0.0",
    "mqtt": "^5.10.3",
    "process": "^0.11.10",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-background-fetch": "^4.2.5",
    "react-native-background-geolocation": "^4.18.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-maps": "1.18.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-webview": "13.12.5",
    "readable-stream": "^3.6.2",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "url": "^0.11.4"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "jimp": "^0.22.10",
    "typescript": "^5.7.2"
  }
}
