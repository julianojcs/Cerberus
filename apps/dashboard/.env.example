# Configuração do dashboard (Next.js). Copie para `.env.local`.
# API pública do Cerberus (Render no MVP; on-prem DTI depois).
NEXT_PUBLIC_API_URL=http://localhost:3000
# Broker MQTT sobre WebSockets (TLS no MVP: wss://<cluster>.hivemq.cloud:8884/mqtt).
NEXT_PUBLIC_MQTT_WS_URL=ws://localhost:9001

# Credencial estática do broker — obrigatória p/ HiveMQ Cloud (MVP público).
# Deixe VAZIO no dev local (Mosquitto sem auth) e no on-prem (auth por JWT):
# sem elas, o dashboard apresenta 'jwt' + o token de login automaticamente.
NEXT_PUBLIC_MQTT_USERNAME=
NEXT_PUBLIC_MQTT_PASSWORD=
