# Contexto de build da imagem da API. Mantém o contexto pequeno e determinístico:
# deps e artefatos são reinstalados/reconstruídos dentro do build.

# dependências e artefatos de build
node_modules
**/node_modules
**/dist
**/.next
**/.turbo
.turbo

# app móvel (Expo, FORA dos workspaces npm — não faz parte da imagem da API)
apps/mobile

# git, CI, editores
.git
.gitignore
.github
.vscode

# ambiente e segredos (nunca entram na imagem)
.env
.env.*
!.env.example

# temporários, artefatos e mídia
*.log
coverage
**/*.pdf
*.png
docs
